# Copy to .env and fill. NEVER commit .env.

# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-...

# === Postgres (pgvector) ===
# Option A — Neon serverless (recommended; pgvector preinstalled).
# Create a project at https://neon.tech (free), copy the connection string here:
# POSTGRES_DSN=postgresql://user:pass@ep-xxx.neon.tech/cdrag?sslmode=require
POSTGRES_DSN=

# Option B — local (docker compose / native postgres). Only used if POSTGRES_DSN is empty.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=cdrag
POSTGRES_PASSWORD=cdrag_dev
POSTGRES_DB=cdrag

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Langfuse (self-hosted observability) ===
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# === Model routing ===
MODEL_SIMPLE=claude-haiku-4-5-20251001
MODEL_COMPLEX=claude-sonnet-4-6
MODEL_FALLBACK_LOCAL=qwen2.5:7b

# === Retrieval ===
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5

# === Cache ===
SEMANTIC_CACHE_THRESHOLD=0.93
CACHE_TTL_SECONDS=86400
